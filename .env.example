# Banco de dados (PostgreSQL via Supabase, ou deixe vazio para SQLite local)
DATABASE_URL=postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres

# JWT
SECRET_KEY=troque-por-uma-chave-aleatoria-de-256-bits
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Supabase Storage (para upload de arquivos)
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_KEY=[anon-key-ou-service-role-key]

# IA semântica para validação de termos (opcional — habilita o Caso 4 na validação de segmentos)
# Obtenha gratuitamente em aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
